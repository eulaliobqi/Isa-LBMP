// ============================================================================
// Isa-LBMP — nextflow.config
// Busca de homólogos FT-like (PEBP) em Urochloa ruziziensis
// ============================================================================

params {
    // ── Entrada ──────────────────────────────────────────────────────────
    genome          = "${projectDir}/sequencias cromossomos brizantha unidas.txt"
    query_proteins  = "${projectDir}/reference_queries.fasta"
    phylo_reference = null   // se null, usa query_proteins; aponte para um FASTA
                              // expandido com TFL1-like/MFT-like para discriminar
                              // ortologia na filogenia (Decisão 3 do plano científico)
    outdir          = "${System.getenv('HOME')}/isa-lbmp/results"

    // ── TBLASTN (triagem ampla) ──────────────────────────────────────────
    tblastn_evalue      = '1e-5'
    tblastn_max_targets = 50
    tblastn_max_hsps    = 10

    // ── Consolidação de loci ─────────────────────────────────────────────
    cluster_distance_bp = 20000   // funde hits a <20kb em um único locus candidato

    // ── HMMER / domínio PEBP ─────────────────────────────────────────────
    pfam_id      = 'PF01161'
    // Reaproveita dado (não código/execução) já baixado pelo projeto Kerson-paper
    // no mesmo servidor — ver README seção "Bloqueios de rede conhecidos".
    pfam_a_hmm   = '/home/eulalio/databases/pfam/Pfam-A.hmm'
    hmmer_evalue = '1e-5'

    // ── Reciprocal Best Hit — proteomas de referência completos ─────────
    // Oryza sativa no MESMO assembly (ASM3414082v1) de onde reference_queries.fasta
    // e a sequência genômica dos 4 genes foram extraídas — evita inconsistência
    // de coordenadas/anotação entre etapas.
    ref_proteomes = [
        [name: 'oryza_sativa',         accession: 'GCF_034140825.1', taxon: 'Oryza sativa (ASM3414082v1)'],
        [name: 'zea_mays',             accession: 'GCF_902167145.1', taxon: 'Zea mays (Zm-B73-REFERENCE-NAM-5.0)'],
        [name: 'arabidopsis_thaliana', accession: 'GCF_000001735.4', taxon: 'Arabidopsis thaliana (TAIR10.1)']
    ]
    rbh_evalue = '1e-10'
    // Cache local dos proteomas — necessário para o fallback manual Windows→scp
    // quando o servidor não conseguir baixar via NCBI datasets CLI (bloqueio de rede).
    local_ref_proteomes_dir = "${System.getenv('HOME')}/isa-lbmp/ref_proteomes_cache"

    // ── Filogenia ─────────────────────────────────────────────────────────
    iqtree_model     = 'MFP'
    iqtree_bootstrap = 1000

    threads = 32
}

profiles {
    local {
        includeConfig 'conf/local.config'
    }

    // Default recomendado: env único fixo "isa-lbmp" (mesmo padrão do MD-gromacs)
    mamba {
        conda.enabled  = true
        conda.useMamba = true
        process.conda  = "${System.getenv('HOME')}/miniforge3/envs/isa-lbmp"
    }

    // Alternativa/portabilidade: conda directive por processo (nf-core style),
    // útil quando o env único "isa-lbmp" ainda não existe ou para CI/portabilidade.
    conda {
        conda.enabled  = true
        conda.useMamba = true
    }
}

includeConfig 'conf/base.config'

report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
    overwrite = true
}
timeline {
    enabled = true
    file    = "${params.outdir}/timeline.html"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.outdir}/dag.svg"
    overwrite = true
}

manifest {
    name            = 'Isa-LBMP'
    description     = 'Busca de homólogos FT-like (PEBP, PF01161) em Urochloa ruziziensis'
    author          = 'Eulalio Santos (UFV) / colaboradora Isa (LBMP)'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
}
