// ============================================================================
// conf/base.config — recursos por label de processo
// Pipeline 100% CPU (sem GPU) — adaptado da tabela usada em MD-gromacs
// ============================================================================

process {
    errorStrategy = 'retry'
    maxRetries    = 1

    withLabel: 'process_low' {
        cpus   = 2
        memory = '4.GB'
        time   = '2.h'
    }
    withLabel: 'process_medium' {
        cpus   = 8
        memory = '16.GB'
        time   = '12.h'
    }
    withLabel: 'process_high' {
        cpus   = 32
        memory = '32.GB'
        time   = '24.h'
    }
}
